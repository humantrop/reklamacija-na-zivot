generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  role       Role     @default(USER)
  totalChats Int      @default(0)
  createdAt  DateTime @default(now())
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Stats {
  id                String   @id @default("global")
  totalChatsCreated Int      @default(0)
  totalMessages     Int      @default(0)
  soloChats         Int      @default(0)
  groupChats        Int      @default(0)
  updatedAt         DateTime @updatedAt
}

model CategoryStat {
  id         String @id
  label      String
  usageCount Int    @default(0)
}
